@using GameList.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = $"Register";
}

<h1 class="display-4">Create account</h1>
<div class="row">
    <div  class="col-md-4">
        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="email" asp-for="Email" class="form-control" aria-required="true" placeholder="Email"/> <br />
            <input type="text" asp-for="Username" class="form-control" aria-required="true" placeholder="Username"/> <br />
            <input type="password" asp-for="Password" class="form-control" aria-required="true" placeholder="Password"/> <br />

            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
