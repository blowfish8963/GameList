@using GameList.ViewModels;
@model LoginViewModel

@{
    ViewData["Title"] = $"Login";
}

<h1 class="display-4">Login</h1>
<div>
    <div class="col-md-4">
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="text" asp-for="Username" class="form-control" aria-required="true" placeholder="Username"/> <br />
            <input type="password" asp-for="Password" class="form-control" aria-required="true" placeholder="Password"/> <br />

            <button type="submit" class="btn btn-primary">Login</button>
        </form>
    </div>
<div>